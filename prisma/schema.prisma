generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id        String   @id @default(cuid())
  email     String?  @unique  // 邮箱（可选，用于注册用户）
  deviceId  String?  @unique  // 设备标识（可选，用于匿名用户）
  phone     String?  @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scans     Scan[]
  familyMembers FamilyMember[]

  @@map("users")
}

// 家庭成员表
model FamilyMember {
  id        String @id @default(cuid())
  userId    String
  name      String
  relation  String  // 关系：配偶、子女、父母
  birthDate DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans  Scan[]

  @@map("family_members")
}

// 检测记录表
model Scan {
  id             String    @id @default(cuid())
  userId         String?
  familyMemberId String?
  deviceId       String?   // 设备标识（临时方案，无用户系统时使用）

  // 原始图片
  imageUrl       String
  imageHash      String   // 用于去重

  // 分析状态
  status         ScanStatus @default(PENDING)

  // 结果
  overallScore   Int?
  issues         Json?    // 问题列表
  recommendations Json?   // 建议
  notes          String?  // 备注

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User?          @relation(fields: [userId], references: [id])
  familyMember   FamilyMember?  @relation(fields: [familyMemberId], references: [id])

  @@map("scans")
}

enum ScanStatus {
  PENDING
  UPLOADING
  PREPROCESSING
  ANALYZING
  COMPLETED
  FAILED
}

// 挑战模型 - 用于好友PK功能
model Challenge {
  id            String          @id @default(cuid())
  creatorScanId String
  creatorName   String
  creatorScore  Int
  friendName    String?
  friendScanId  String?
  friendScore   Int?
  status        ChallengeStatus @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  expiresAt     DateTime?

  @@map("challenges")
}

enum ChallengeStatus {
  PENDING     // 等待接受
  ACCEPTED    // 已接受，等待完成
  COMPLETED   // 双方完成，可查看结果
  EXPIRED     // 已过期
  CANCELLED   // 已取消
}
